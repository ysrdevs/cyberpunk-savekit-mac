<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CP2077SaveKit.App.ViewModels"
        xmlns:core="using:CP2077SaveKit.Core"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="640"
        x:Class="CP2077SaveKit.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="940" Height="680"
        Title="CP2077 Save Kit">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="12">
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8">
            <Button Name="OpenBtn" Content="Open Save…"/>
            <Button Name="SaveAsBtn" Content="Save As…" IsEnabled="{Binding IsLoaded}"/>
            <Button Content="Check for Updates" Command="{Binding CheckForUpdatesCommand}"/>
            <TextBlock Text="{Binding LoadedPath}" VerticalAlignment="Center" Opacity="0.7"
                       TextTrimming="CharacterEllipsis" MaxWidth="480"/>
        </StackPanel>

        <!-- Update available banner (only shows when a newer release exists) -->
        <Border DockPanel.Dock="Top" Margin="0,10,0,0" Padding="10,7" CornerRadius="4"
                IsVisible="{Binding UpdateAvailable}"
                Background="#2200E5FF" BorderBrush="#6600E5FF" BorderThickness="1">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="Download" Command="{Binding OpenUpdateCommand}"/>
                <TextBlock Text="{Binding UpdateText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <!-- Save picker (from the default Cyberpunk saves folder) -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,10,0,0">
            <TextBlock Text="Your saves:" VerticalAlignment="Center"/>
            <ComboBox Width="430" ItemsSource="{Binding SaveList}" SelectedItem="{Binding SelectedSave}"
                      PlaceholderText="pick a save to load">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="core:SaveEntry">
                        <TextBlock Text="{Binding Display}" FontFamily="monospace"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <CheckBox Content="Manual saves only" IsChecked="{Binding ManualOnly}" VerticalAlignment="Center"/>
            <Button Content="Refresh" Command="{Binding RefreshSavesCommand}"/>
        </StackPanel>

        <!-- Safety tip -->
        <Border DockPanel.Dock="Top" Margin="0,10,0,0" Padding="10,7" CornerRadius="4"
                Background="#1AF5E003" BorderBrush="#66F5E003" BorderThickness="1">
            <TextBlock TextWrapping="Wrap"
                       Text="Tip: for the safest experience, edit a Manual Save. Make a manual save in the game first, edit that one here, and keep a backup. Auto-saves and quick-saves can be overwritten by the game at any time."/>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="#22000000" Padding="8,6" Margin="0,8,0,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="120" Height="6"
                             IsVisible="{Binding IsBusy}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Status}" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Margin="0,10,0,0">
            <!-- ================= Inventory tab ================= -->
            <TabItem Header="Inventory">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,8"
                                IsEnabled="{Binding IsLoaded}">
                        <TextBlock Text="Eddies:" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding Money}" Width="160"/>
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        <TextBox Text="{Binding Search}" Width="300" Watermark="filter items by name or hash"/>
                    </StackPanel>
                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4">
                        <ListBox ItemsSource="{Binding Items}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:ItemRow">
                                    <Grid ColumnDefinitions="*,120,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Display}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBox  Grid.Column="1" Text="{Binding Quantity}" Margin="8,2"/>
                                        <TextBlock Grid.Column="2" Text="{Binding HashHex}" VerticalAlignment="Center"
                                                   Opacity="0.45" FontFamily="monospace" Margin="8,0,4,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>

            <!-- ================= Add Item tab ================= -->
            <TabItem Header="Add Item">
                <DockPanel IsEnabled="{Binding IsLoaded}">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,8">
                        <TextBlock Text="Category:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" Width="140"/>
                        <TextBlock Text="Search:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBox Text="{Binding CatalogSearch}" Width="240"
                                 Watermark="malorian, katana, sandevistan…"/>
                        <TextBlock Text="Qty:" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        <TextBox Text="{Binding AddQuantity}" Width="80"/>
                        <Button Content="Add Selected" Command="{Binding AddSelectedItemCommand}"/>
                    </StackPanel>
                    <TextBlock DockPanel.Dock="Bottom" Margin="2,6,0,0" Opacity="0.55" TextWrapping="Wrap"
                               Text="All 7,552 items: weapons, cyberware, clothing, mods, components, consumables, grenades. Gear is added at base stats (the game finalizes stats/mods on load). Qty applies to stackables. Edits apply on Save As…"/>
                    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="4">
                        <ListBox ItemsSource="{Binding CatalogResults}"
                                 SelectedItem="{Binding SelectedCatalogItem}">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:CatalogItem">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Id}" VerticalAlignment="Center"
                                                   Opacity="0.45" FontFamily="monospace" Margin="8,0,4,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </DockPanel>
            </TabItem>
            <!-- ================= Attributes & Perks tab ================= -->
            <TabItem Header="Attributes &amp; Perks">
                <ScrollViewer>
                    <StackPanel Spacing="14" Margin="2,8" IsEnabled="{Binding IsLoaded}">
                        <TextBlock Text="Core Attributes" FontWeight="Bold"/>
                        <ItemsControl ItemsSource="{Binding Attributes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AttrRow">
                                    <Grid ColumnDefinitions="220,140" Margin="0,2">
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"/>
                                        <TextBox  Grid.Column="1" Text="{Binding Value}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Development Points (edit Unspent)" FontWeight="Bold" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding DevPoints}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:PointsRow">
                                    <Grid ColumnDefinitions="220,140,Auto" Margin="0,2">
                                        <TextBlock Grid.Column="0" Text="{Binding Type}" VerticalAlignment="Center"/>
                                        <TextBox  Grid.Column="1" Text="{Binding Unspent}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Spent, StringFormat='spent: {0}'}"
                                                   VerticalAlignment="Center" Opacity="0.5" Margin="10,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Opacity="0.55" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Attributes cap at 20 in-game (the editor lets you set any value). Relic Points are the Phantom Liberty Relic tree. Edits apply on Save As…"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
